%global goipath         github.com/containers/oci-delta

Version:        @@VERSION@@

%gometa

Name:           oci-delta
Release:        1%{?dist}
Summary:        Create and apply delta files between OCI image archives

License:        Apache-2.0

URL:            %{gourl}
Source0:        https://github.com/containers/oci-delta/releases/download/v%{version}/oci-delta-%{version}.tar.gz

BuildRequires:  %{?go_compiler:compiler(go-compiler)}%{!?go_compiler:golang}
BuildRequires:  glib2-devel
BuildRequires:  pkgconfig
%if 0%{?fedora}
# DO NOT REMOVE the BUNDLE_START and BUNDLE_END markers as they are used by 'tools/rpm_spec_add_provides_bundle.sh' to generate the Provides: bundled list
# BUNDLE_START
# BUNDLE_END
%endif

%description
Creates and applies delta files between OCI image archives for bootc
systems. Delta files are significantly smaller than full OCI archives
because they exclude layers already present on the target system and
use binary diffs (tar-diff) for changed layers.

%prep
%if 0%{?rhel}
%forgeautosetup -p1
%else
%goprep -k
%endif

%build
export GOFLAGS="-buildmode=pie"
%if 0%{?rhel}
GO_BUILD_PATH=$PWD/_build
install -m 0755 -vd $(dirname $GO_BUILD_PATH/src/%{goipath})
ln -fs $PWD $GO_BUILD_PATH/src/%{goipath}
cd $GO_BUILD_PATH/src/%{goipath}
install -m 0755 -vd _bin
export PATH=$PWD/_bin${PATH:+:$PATH}
export GOPATH=$GO_BUILD_PATH:%{gopath}
export GOFLAGS+=" -mod=vendor"
%endif

%if 0%{?fedora}
# Fedora disables Go modules by default, but we want to use them.
# Undefine the macro which disables it to use the default behavior.
%undefine gomodulesmode
%endif

%gobuild -o _bin/oci-delta %{goipath}/cmd/oci-delta

%install
install -m 0755 -vd                          %{buildroot}%{_bindir}
install -m 0755 -vp _bin/oci-delta           %{buildroot}%{_bindir}/

%check
export GOFLAGS="-buildmode=pie"
%if 0%{?rhel}
export GOFLAGS+=" -mod=vendor"
export GOPATH=$PWD/_build:%{gopath}
cd $PWD/_build/src/%{goipath}
%gotest ./...
%else
%gocheck
%endif

%files
%doc README.md
%{_bindir}/oci-delta

%changelog
* Thu May 29 2025 Alexander Larsson <alexl@redhat.com> - 0.1.0-1
- Initial RPM packaging
